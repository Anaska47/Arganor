{
  "name": "arganor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "runtime:pull": "node src/scripts/sync-runtime-content.js pull",
    "runtime:push": "node src/scripts/sync-runtime-content.js push",
    "runtime:sync": "node src/scripts/sync-runtime-content.js both",
    "validate:autopilot": "node src/scripts/validate-autopilot.js",
    "autopilot": "node src/scripts/autopilot-content.js && node src/scripts/pinterest-bot.js",
    "autopilot:local": "node src/scripts/run-autopilot-local.js",
    "autopilot:local:keep": "node src/scripts/run-autopilot-local.js --keep",
    "autopilot:local:fast": "node src/scripts/run-autopilot-local.js --skip-build"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.103.0",
    "clsx": "^2.1.1",
    "jimp": "^1.6.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
